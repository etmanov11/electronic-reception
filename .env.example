# ==========================================
# Переменные окружения для production
# ==========================================
# Скопируйте этот файл в .env и заполните значения

# Django
SECRET_KEY=сгенерируйте-уникальный-ключ-здесь
DEBUG=False
ALLOWED_HOSTS=ваш-домен.ru,www.ваш-домен.ru

# PostgreSQL (Railway/Render заполняют автоматически)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (для Celery, опционально)
REDIS_URL=redis://localhost:6379/0

# Email (опционально)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@ваш-домен.ru
